import("//base/notification/distributed_notification_service/notification.gni")
import("//build/ohos.gni")
import("//build/test.gni")

module_output_path = "${component_name}/distributed_notification_service/unittest"

ohos_unittest("pixelmap_cache_manager_test") {
  module_out_path = module_output_path
  include_dirs = [
    "${core_path}/include",
    "${core_path}/common/include",
    "${inner_api_path}",
  ]

  sources = [
    "${core_path}/src/pixelmap_cache_manager.cpp",
    "pixelmap_cache_manager_test.cpp",
  ]

  deps = [
    "${frameworks_module_ans_path}:ans_innerkits",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "image_framework:image",
    "image_framework:pixelmap",
  ]

  subsystem_name = "${subsystem_name}"
  part_name = "${component_name}"
}

group("unittest") {
  testonly = true
  deps = []

  deps += [ ":pixelmap_cache_manager_test" ]
}