{
  "name": "ohos-notificationManager",
  "version": "1.0.0",
  "description": "OpenHarmony notification management tool. Used for notification publishing, cancellation, removal, and querying active notifications. Does not support notification subscription or interactive UI operations.",
  "executablePath": "/system/bin/cli_tool/executable/ohos-notificationManager",
  "requirePermissions": [
    "ohos.permission.NOTIFICATION_CONTROLLER",
    "ohos.permission.NOTIFICATION_AGENT_CONTROLLER"
  ],
  "hasSubCommand": true,
  "inputSchema": {
    "type": "object",
    "properties": {}
  },
  "outputSchema": {
    "type": "object",
    "properties": {}
  },
  "subcommands": {
    "publish": {
      "description": "Publish a notification. Used for sending notifications to the system. Does not support subscription-type notifications.",
      "requirePermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "notificationId": {
            "type": "integer",
            "description": "通知ID",
            "default": 0
          },
          "notificationContent": {
            "type": "string",
            "description": "通知内容JSON字符串。所有类型公共必填: title(≤1024B), text(≤3072B)；公共可选: additionalText(≤3072B)；所有属性超长截取。type仅支持basic、long_text、multiline:\nbasic示例: {\"type\":\"basic\",\"title\":\"通知标题\",\"text\":\"通知内容\",\"additionalText\":\"附加文本\"}\nlong_text: longText(≤3072B)、expandedTitle(≤1024B)、briefText(≤1024B)，超长截取。示例: {\"type\":\"long_text\",\"title\":\"通知标题\",\"text\":\"短内容\",\"longText\":\"长文本内容\",\"expandedTitle\":\"展开标题\",\"briefText\":\"摘要\",\"additionalText\":\"附加文本\"}\nmultiline: expandedTitle(≤1024B)、briefText(≤1024B)、lines(≤3个元素,每个≤1024B)，超长截取。示例: {\"type\":\"multiline\",\"title\":\"通知标题\",\"text\":\"通知内容\",\"expandedTitle\":\"展开标题\",\"briefText\":\"摘要\",\"lines\":[\"第一行\",\"第二行\",\"第三行\"],\"additionalText\":\"附加文本\"}"
          },
          "slotType": {
            "type": "integer",
            "description": "通知渠道类型（0=社交通信, 1=服务提醒, 2=内容信息, 3=其他, 6=客服消息，不支持4=自定义、5=实况通知、7=紧急信息）",
            "minimum": 0,
            "maximum": 6,
            "default": 3
          },
          "updateOnly": {
            "type": "boolean",
            "description": "仅更新已存在的通知，不创建新通知",
            "default": false
          },
          "appMessageId": {
            "type": "string",
            "description": "应用消息ID，用于标识特定消息"
          },
          "priorityNotificationType": {
            "type": "string",
            "description": "优先级通知类型，枚举值: OTHER(非优先级通知)、PRIMARY_CONTACT(重要联系人)、AT_ME(有人@我)、URGENT_MESSAGE(紧急消息)、SCHEDULE_REMINDER(日程提醒)",
            "enum": ["OTHER", "PRIMARY_CONTACT", "AT_ME", "URGENT_MESSAGE", "SCHEDULE_REMINDER"]
          },
          "alertOneTime": {
            "type": "boolean",
            "description": "仅提醒一次，后续更新不再提醒",
            "default": false
          },
          "sound": {
            "type": "string",
            "description": "自定义通知声音URI"
          },
          "badgeNumber": {
            "type": "integer",
            "description": "通知角标增加数量（设置为在当前角标基础上增加的数字，必须>=0）"
          },
          "autoDeletedTime": {
            "type": "number",
            "description": "自动删除时间（毫秒）"
          },
          "label": {
            "type": "string",
            "description": "通知标签（不超过204字节）"
          },
          "groupName": {
            "type": "string",
            "description": "通知分组名称（不超过204字节，超长截取）"
          },
          "notificationFlags": {
            "type": "string",
            "description": "通知提醒标志JSON字符串。支持字段: soundEnabled(声音)、vibrationEnabled(振动)、bannerEnabled(横幅)、lockScreenEnabled(锁屏)，值枚举: 2=CLOSE(关闭)。示例: {\"soundEnabled\":2,\"vibrationEnabled\":2}"
          }
        },
        "required": ["notificationContent"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "cancelById": {
      "description": "Cancel notification by bundle and notification ID. Used for managing notifications of specific applications. Does not support canceling notifications without bundle information.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER",
        "ohos.permission.NOTIFICATION_AGENT_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "bundleOption": {
            "type": "string",
            "description": "目标应用信息JSON字符串，包含bundleName(应用包名)和uid(应用UID)两个属性"
          },
          "notificationId": {
            "type": "integer",
            "description": "待取消的通知ID"
          }
        },
        "required": ["bundleOption", "notificationId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "cancelByBundle": {
      "description": "Cancel all notifications for a specified bundle. Used for batch canceling notifications of a specific application.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "bundleOption": {
            "type": "string",
            "description": "目标应用信息JSON字符串，包含bundleName(应用包名)和uid(应用UID)两个属性"
          }
        },
        "required": ["bundleOption"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "batchCancel": {
      "description": "Batch cancel notifications by hashcodes. Used for canceling specific notifications identified by their hashcodes.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "hashcodes": {
            "type": "string",
            "description": "通知哈希码JSON数组字符串，指定要移除的通知列表"
          }
        },
        "required": ["hashcodes"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "enableNotification": {
      "description": "Set notification enabled/disabled for bundle. Used for controlling notification permissions of applications. Does not support setting status without bundle information.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "bundleOption": {
            "type": "string",
            "description": "目标应用信息JSON字符串，包含bundleName(应用包名)和uid(应用UID)两个属性"
          },
          "enabled": {
            "type": "boolean",
            "description": "通知开关状态（true=启用, false=禁用）",
            "default": false
          }
        },
        "required": ["bundleOption", "enabled"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "setSlotFlags": {
      "description": "Set notification slot flags for bundle. Used for configuring notification reminder modes of applications. Does not support setting slot flags without bundle information.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          },
          "bundleOption": {
            "type": "string",
            "description": "目标应用信息JSON字符串，包含bundleName(应用包名)和uid(应用UID)两个属性"
          },
          "flags": {
            "type": "integer",
            "description": "渠道标志位掩码，仅bit0-bit5有效（bit0=声音, bit1=锁屏, bit2=横幅, bit3=亮屏, bit4=振动, bit5=状态栏图标），必须>=0且不能大于0b111111(63)，其中亮屏(bit3)和状态栏图标(bit5)设置关闭不会生效，服务端会强制保持开启"
          }
        },
        "required": ["bundleOption", "flags"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {}
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    },
    "listAllNotification": {
      "description": "List all active notifications. Used for querying current notification status. Does not support listing notifications for other users.",
      "requirePermissions": [
        "ohos.permission.NOTIFICATION_CONTROLLER"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "help": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "事件类型" },
          "status": { "type": "string", "description": "结果状态" },
          "data": {
            "type": "object",
            "properties": {
              "notifications": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "notificationId": { "type": "integer", "description": "通知ID" },
                    "createTime": { "type": "integer", "description": "通知创建时间（毫秒时间戳）" },
                    "ownerUid": { "type": "integer", "description": "通知创建者UID" },
                    "ownerUserId": { "type": "integer", "description": "通知创建者UserId" },
                    "ownerBundleName": { "type": "string", "description": "通知创建者包名" },
                    "label": { "type": "string", "description": "通知标签" },
                    "appInstanceKey": { "type": "string", "description": "应用实例Key" },
                    "slotType": { "type": "integer", "description": "渠道类型值" },
                    "notificationContent": {
                        "type": "object",
                        "description": "通知内容，按type字段区分不同类型。所有类型公共字段: type(类型名)、title(标题)、text(文本)、additionalText(附加文本，可选)；\nbasic: 仅公共字段；\nlong_text: +longText(长文本)、expandedTitle(展开标题)、briefText(摘要)；\nmultiline: +expandedTitle(展开标题)、briefText(摘要)、lines(行文本数组)；\npicture: +expandedTitle(展开标题)、briefText(摘要)；\nconversation: +conversationTitle(会话标题)、isGroup(是否群聊)、messages(消息数组，含text/arrivedTime/senderName/senderKey)；\nmedia: +shownActions(展示按钮序号数组)；\nlive_view: +liveViewStatus(实况状态)、version(版本号)；\nlocal_live_view: +liveViewType(实况类型)",
                        "properties": {
                            "type": { "type": "string", "description": "内容类型: basic|long_text|multiline|picture|conversation|media|live_view|local_live_view" },
                            "title": { "type": "string", "description": "通知标题" },
                            "text": { "type": "string", "description": "通知文本" },
                            "additionalText": { "type": "string", "description": "附加文本(可选)" },
                            "longText": { "type": "string", "description": "长文本(long_text类型)" },
                            "expandedTitle": { "type": "string", "description": "展开标题(long_text/multiline/picture类型)" },
                            "briefText": { "type": "string", "description": "摘要文本(long_text/multiline/picture类型)" },
                            "lines": { "type": "array", "description": "行文本数组(multiline类型)", "items": { "type": "string" } },
                            "conversationTitle": { "type": "string", "description": "会话标题(conversation类型)" },
                            "isGroup": { "type": "boolean", "description": "是否群聊(conversation类型)" },
                            "messages": { "type": "array", "description": "会话消息列表(conversation类型)", "items": { "type": "object", "properties": { "text": { "type": "string" }, "arrivedTime": { "type": "integer" }, "senderName": { "type": "string" }, "senderKey": { "type": "string" } } } },
                            "shownActions": { "type": "array", "description": "展示按钮序号数组(media类型)", "items": { "type": "integer" } },
                            "liveViewStatus": { "type": "integer", "description": "实况通知状态(live_view类型)" },
                            "version": { "type": "integer", "description": "实况通知版本号(live_view类型)" },
                            "liveViewType": { "type": "integer", "description": "本地实况类型(local_live_view类型)" }
                        }
                    },
                    "actionButtons": { "type": "array", "description": "操作按钮列表", "items": { "type": "object", "properties": { "title": { "type": "string", "description": "按钮标题" } } } },
                    "notificationFlags": { "type": "string", "description": "通知提醒标志，包含soundEnabled、vibrationEnabled、bannerEnabled、lockScreenEnabled等字段" },
                    "hashCode": { "type": "string", "description": "通知哈希码" }
                  }
                },
                "description": "活跃通知列表"
              },
              "total": { "type": "integer", "description": "通知总数" }
            }
          },
          "errCode": { "type": "string", "description": "错误码" },
          "errMsg": { "type": "string", "description": "错误描述" },
          "suggestion": { "type": "string", "description": "建议的下一步操作" }
        }
      }
    }
  }
}