import("//base/notification/distributed_notification_service/notification.gni")
import("//build/ohos.gni")
import("//build/test.gni")

ohos_unittest("system_sound_dynamic_wrapper_test") {
  module_out_path = "${component_name}/distributed_notification_service/unittest"
  
  sources = [
    "${services_path}/ans/src/dynamic_dependency/system_sound_dynamic_wrapper.cpp",
    "system_sound_dynamic_wrapper_test.cpp",
  ]
  
  include_dirs = [
    ".",
    "${services_path}/ans/include",
    "${services_path}/ans/include/dynamic_dependency",
  ]
  deps = [ "${frameworks_module_ans_path}:ans_innerkits" ]
  
  external_deps = [
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ability_runtime:abilitykit_native",
    "audio_framework:audio_client",
    "player_framework:media_client",
    "player_framework:system_sound_client",
  ]
  
  subsystem_name = "${subsystem_name}"
  part_name = "${component_name}"
}

ohos_unittest("screen_manager_dynamic_wrapper_test") {
  module_out_path = "${component_name}/distributed_notification_service/unittest"
  
  sources = [
    "${services_path}/ans/src/dynamic_dependency/screen_manager_dynamic_wrapper.cpp",
    "screen_manager_dynamic_wrapper_test.cpp",
  ]
  
  include_dirs = [
    ".",
    "${services_path}/ans/include",
    "${services_path}/ans/include/dynamic_dependency",
  ]
  deps = [ "${frameworks_module_ans_path}:ans_innerkits" ]
  
  external_deps = [
    "ffrt:libffrt",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "window_manager:libdm",
    "graphic_2d:librender_service_base",
  ]
  
  subsystem_name = "${subsystem_name}"
  part_name = "${component_name}"
}

group("unittest") {
  testonly = true
  deps = [
    ":system_sound_dynamic_wrapper_test",
    ":screen_manager_dynamic_wrapper_test"
  ]
}